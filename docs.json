{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Recepta.ai Voice Agent SaaS",
  "openapi": "api-reference/openapi.json",
  "colors": {
    "primary": "#667EEA",
    "light": "#9CA3F4",
    "dark": "#4C63D2"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "setup/authentication",
              "setup/onboarding"
            ]
          },
          {
            "group": "AI Voice Agents",
            "pages": [
              "agents/overview",
              "agents/creation",
              "agents/configuration",
              "agents/management"
            ]
          },
          {
            "group": "Chat Widget",
            "pages": [
              "chat-widget/overview",
              "chat-widget/setup",
              "chat-widget/customization",
              "chat-widget/integration"
            ]
          },
          {
            "group": "Features",
            "pages": [
              "features/call-management",
              "features/call-logs",
              "features/knowledge-base",
              "features/qa-system",
              "features/analytics",
              "features/phone-numbers"
            ]
          },
          {
            "group": "Call Forwarding Guides",
            "pages": [
              "call-forwarding/conditional-forwarding",
              "call-forwarding/callrail",
              "call-forwarding/dialpad",
              "call-forwarding/ringcentral",
              "call-forwarding/8x8",
              "call-forwarding/google-voice",
              "call-forwarding/phonecom",
              "call-forwarding/talkroute",
              "call-forwarding/vonage"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "advanced/webhooks",
              "advanced/custom-prompts",
              "advanced/integrations"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Calls",
            "pages": [
              { "openapi": "GET /api/calls" },
              { "openapi": "POST /api/calls/outbound" },
              { "openapi": "GET /api/calls/search" },
              { "openapi": "GET /api/calls/analytics" },
              { "openapi": "GET /api/calls/{callId}" },
              { "openapi": "DELETE /api/calls/{callId}" },
              { "openapi": "GET /api/calls/{callId}/transcript" },
              { "openapi": "GET /api/calls/{callId}/recording" }
            ]
          },
          {
            "group": "Contacts",
            "pages": [
              { "openapi": "GET /api/contacts" },
              { "openapi": "POST /api/contacts" },
              { "openapi": "GET /api/contacts/{clientId}" },
              { "openapi": "PUT /api/contacts/{clientId}" },
              { "openapi": "DELETE /api/contacts/{clientId}" }
            ]
          },
          {
            "group": "SMS",
            "pages": [
              { "openapi": "GET /api/sms" },
              { "openapi": "POST /api/sms/send" },
              { "openapi": "GET /api/sms/{conversationId}/messages" }
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "href": "https://mintlify.com/docs",
          "icon": "book-open-cover"
        },
        {
          "anchor": "Community",
          "href": "https://mintlify.com/community",
          "icon": "slack"
        },
        {
          "anchor": "Blog",
          "href": "https://mintlify.com/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.png",
    "dark": "/logo/dark.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@recepta.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://recepta.ai"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/receptaai",
      "github": "https://github.com/receptaai",
      "linkedin": "https://linkedin.com/company/recepta-ai"
    }
  }
}
